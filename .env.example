# Environment Variables for JUP App
# ===================================
#
# These variables are now set via --dart-define at build time.
# This file is kept for documentation purposes.
#
# For LOCAL DEVELOPMENT, configure your IDE's launch configuration:
#
# VS Code (launch.json):
#   "args": [
#     "--dart-define=STRAPI_BASE_URL=http://localhost:1337",
#     "--dart-define=STRAPI_API_TOKEN=your-token",
#     ...
#   ]
#
# Android Studio (Run Configuration → Additional run args):
#   --dart-define=STRAPI_BASE_URL=http://localhost:1337 --dart-define=STRAPI_API_TOKEN=your-token
#
# Command line:
#   flutter run --dart-define=STRAPI_BASE_URL=http://localhost:1337 --dart-define=STRAPI_API_TOKEN=your-token
#
# For CI/CD, these are set in GitLab CI/CD Variables.
#
# ===================================

# Strapi Backend Configuration
# -----------------------------------
# Production/Development Strapi URL
STRAPI_BASE_URL=http://localhost:1337

# For local development on emulators/simulators:
# - Android Emulator: use 10.0.2.2 to reach host machine
# - iOS Simulator: can use localhost or your Mac's IP
# Find your IP with: ipconfig getifaddr en0 (Mac)
STRAPI_BASE_URL_MACHINE=

# Strapi API Token
# Generate in Strapi Admin Panel: Settings → API Tokens → Create new API Token
# IMPORTANT: Use different tokens for development, staging, and production
# Rotate tokens regularly and revoke old ones
STRAPI_API_TOKEN=your-api-token-here

# Matomo Analytics Configuration
# -----------------------------------
# URL to your Matomo instance (without trailing slash)
MATOMO_URL=https://your-matomo-instance.com

# Site ID from Matomo Dashboard (Administration → Websites)
MATOMO_SITE_ID=1

# Salt for pseudonymizing user IDs (use a secure random value in production)
MATOMO_USER_SALT=your-secure-random-salt-here

# Support Configuration
# -----------------------------------
# Support Email Address for User Inquiries
SUPPORT_EMAIL=
